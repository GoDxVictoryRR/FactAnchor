# PostgreSQL
POSTGRES_HOST=pgbouncer          # Always connect through pgBouncer, never direct
POSTGRES_PORT=5432
POSTGRES_DB=factanchor
POSTGRES_USER=factanchor_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
RABBITMQ_MGMT_USER=guest
RABBITMQ_MGMT_PASSWORD=CHANGE_ME

# Redis (Celery result backend)
REDIS_URL=redis://redis:6379/0

# Pinecone
PINECONE_API_KEY=CHANGE_ME
PINECONE_INDEX_NAME=factanchor-claims
PINECONE_ENVIRONMENT=us-east-1-aws

# LLM (for SQL generation from claim text)
# Supports: openai, anthropic, azure_openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6
LLM_API_KEY=CHANGE_ME
LLM_MAX_TOKENS=1024

# Auth
JWT_SECRET_KEY=CHANGE_ME_256_BIT_RANDOM_HEX
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
API_KEY_HEADER=X-FactAnchor-Key

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# App
APP_ENV=development              # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Initial Admin (Optional - created on first run if set)
# INITIAL_ADMIN_EMAIL=admin@example.com
# INITIAL_ADMIN_PASSWORD=STRONG_PASSWORD_HERE
